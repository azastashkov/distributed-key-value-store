        </mxCell>

        <!-- ============================================================ -->
        <!-- Cluster Layer -->
        <!-- ============================================================ -->
        <mxCell id="cluster-layer" value="&lt;b&gt;Cluster Layer&lt;/b&gt;&amp;nbsp;&amp;nbsp;(org.dkvs.cluster)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=8;spacingTop=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="570" height="370" as="geometry"/>
        </mxCell>

        <mxCell id="cluster-service" value="&lt;b&gt;ClusterService&lt;/b&gt;&#xa;&#xa;• Membership management&#xa;• Alive node tracking&#xa;• Hash ring updates&#xa;• Failure detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="950" y="140" width="230" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="gossip-service" value="&lt;b&gt;GossipService&lt;/b&gt;&#xa;&#xa;• @Scheduled heartbeat&#xa;• Periodic peer selection&#xa;• State merge (higher HB wins)&#xa;• Seed node bootstrap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="1210" y="140" width="240" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="hash-ring" value="&lt;b&gt;ConsistentHashRing&lt;/b&gt;&#xa;&#xa;• SHA-256 hashing&#xa;• 150 virtual nodes / physical node&#xa;• Clockwise replica selection&#xa;• getReplicaNodes(key, n)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="950" y="280" width="250" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="node-model" value="&lt;b&gt;Node&lt;/b&gt;&#xa;&#xa;id, host, port&#xa;heartbeat, status&#xa;(UP / DOWN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="1230" y="280" width="220" height="110" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- Storage Layer -->
        <!-- ============================================================ -->
        <mxCell id="storage-layer" value="&lt;b&gt;Storage Layer&lt;/b&gt;&amp;nbsp;&amp;nbsp;(org.dkvs.storage)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=8;spacingTop=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="520" width="1180" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="storage-engine" value="&lt;b&gt;StorageEngine&lt;/b&gt;&#xa;&#xa;• Orchestrates write: CommitLog → MemTable&#xa;• Orchestrates read: MemTable → SSTables&#xa;• Triggers flush when threshold exceeded&#xa;• Crash recovery via CommitLog replay&#xa;• Prometheus metrics (key count, memtable size, sstable count)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="560" width="380" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="commit-log" value="&lt;b&gt;CommitLog&lt;/b&gt;&#xa;(Write-Ahead Log)&#xa;&#xa;• Append-only binary file&#xa;• Format: keyLen | key |&#xa;  dataLen | data | ver | ts&#xa;• Replay for crash recovery&#xa;• Reset after flush" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="340" y="730" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="memtable" value="&lt;b&gt;MemTable&lt;/b&gt;&#xa;(In-Memory Cache)&#xa;&#xa;• ConcurrentSkipListMap&#xa;• Sorted key order&#xa;• Size tracking (bytes)&#xa;• Flush threshold: 1 MB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="590" y="730" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="sstable-mgr" value="&lt;b&gt;SSTableManager&lt;/b&gt;&#xa;&#xa;• Holds list of SSTables&#xa;  (chronological order)&#xa;• Searches newest-first&#xa;• BloomFilter pre-check&#xa;• Loads existing on startup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="840" y="730" width="230" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="sstable" value="&lt;b&gt;SSTable&lt;/b&gt;&#xa;(Immutable Sorted File)&#xa;&#xa;• Binary format on disk&#xa;• Data section + Index + Footer&#xa;• O(log n) binary search lookup&#xa;• Created at MemTable flush" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="1100" y="730" width="230" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="bloom-filter" value="&lt;b&gt;BloomFilter&lt;/b&gt;&#xa;&#xa;• Probabilistic membership test&#xa;• SHA-256 + Kirsch-Mitzenmacher&#xa;• 1% false positive rate&#xa;• Serialized per SSTable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
