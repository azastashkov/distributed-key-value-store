        </mxCell>

        <mxCell id="coordinator-service" value="&lt;b&gt;CoordinatorService&lt;/b&gt;&#xa;&#xa;• Quorum-based PUT (W acks)&#xa;• Quorum-based GET (R responses)&#xa;• Parallel async replication via virtual threads&#xa;• Version resolution (highest wins)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingTop=2;" vertex="1" parent="1">
